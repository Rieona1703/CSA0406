#include <stdio.h>
#include <unistd.h>

int main() {
    pid_t pid1, pid2;

    pid1 = fork();

    if (pid1 == 0) {
        // First child process
        printf("First Child Process ID: %d\n", getpid());
    }
    else {
        pid2 = fork();

        if (pid2 == 0) {
            // Second child process
            printf("Second Child Process ID: %d\n", getpid());
        }
        else {
            // Parent process
            printf("Parent Process ID: %d\n", getpid());
        }
    }

    return 0;
}
