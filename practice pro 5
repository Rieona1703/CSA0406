#include <stdio.h>
#include <unistd.h>

int main() {
    int i;

    for (i = 1; i <= 3; i++) {
        if (fork() == 0) {
            printf("Child %d: PID = %d, PPID = %d\n", i, getpid(), getppid());
            return 0;
        }
    }

    printf("Parent: PID = %d\n", getpid());

    return 0;
}
