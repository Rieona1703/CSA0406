#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
#include <sys/wait.h>

int main() {
    pid_t pid = fork();

    if (pid == 0) {
        printf("Child process is running\n");
        exit(0);
    }
    else {
        wait(NULL);
        printf("Parent: Child process completed\n");
    }

    return 0;
}
